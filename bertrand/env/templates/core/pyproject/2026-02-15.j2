[build-system]
requires = ["bertrand"]
build-backend = "bertrand.build"

[project]
name = "{{ project_name }}"
version = "0.1.0"
dependencies = [                    # Python-level dependencies
    "bertrand=={{ bertrand_major }}.{{ bertrand_minor }}.{{ bertrand_patch }}",
]
requires-python = "{{ python_major }}.{{ python_minor }}"
authors = [
    # e.g. { name = "my name", email = "my@email.com" },
]
maintainers = [
    # e.g. { name = "my name", email = "my@email.com" },
]
description = "Bertrand project"
readme = "README.md"
license = "MIT"                     # SPDX license identifier (e.g. MIT, Apache-2.0, etc.)
license-files = ["LICEN[CS]E.*"]    # list of relative (posix) paths from worktree root
classifiers = [
    "Programming Language :: C++",
    "Programming Language :: Python :: {{ python_major }}.{{ python_minor }}",
]

[project.urls]
Homepage = "https://example.com"
Documentation = "https://readthedocs.org"
Repository = "https://github.com/myusername/myrepo"
"Bug Tracker" = "https://github.com/myusername/myrepo/issues"

##################
####    UV    ####
##################

[tool.uv]
managed = true                              # treat this as a uv-managed project
required-version = "{{ uv_major }}.{{ uv_minor }}.{{ uv_patch }}"                  # toolchain uv version
python-preference = "only-system"           # prefer the container-provided Python interpreter
python-downloads = "never"                  # never download Python runtimes implicitly
index-strategy = "first-index"              # stop at first index with a package (safer defaults)
resolution = "highest"                      # pick highest compatible versions when resolving
prerelease = "if-necessary-or-explicit"     # include prereleases only when required

# Optional custom indexes
# [[tool.uv.index]]
# name = "internal"
# url = "https://example.com/simple"
# explicit = true                           # if true, indexed packages must be declared in [tool.uv.sources]
# default = true                            # replaces PyPI as the default index when true

#####################
####    CONAN    ####
#####################

[tool.bertrand.conan]
requires = []           # e.g. ["fmt/11.0.2", "nlohmann_json/3.12.0"]
tool_requires = []      # e.g. ["cmake/3.30.5", "ninja/1.12.1"]
options = {}            # e.g. { "fmt/*:header_only" = true }
conf = {}               # e.g. { "tools.build:jobs" = 16 }
build_type = "Release"  # Release|Debug (may be overridden in build matrix tags)

# NOTE: Conan remotes are resolved in declaration order.  Prefer private remotes first,
# then optional public fallback remotes last.  Credentials are host-local and must
# never be stored here; resolve through env/secret channels (e.g.
# CONAN_LOGIN_USERNAME_<REMOTE>, CONAN_PASSWORD_<REMOTE>, with remote names normalized
# to SCREAMING_SNAKE_CASE).

# [[tool.conan.remotes]]
# name = "internal"
# url = "https://conan.example.com"
# verify_ssl = true
# enabled = true
# recipes_only = false
# allowed_packages = ["myorg/*", "thirdparty/*"]

########################
####    BERTRAND    ####
########################

[tool.bertrand]
max_commits = {{ max_commits }}            # number of commits to store, after which LRU eviction begins
shell = "{{ shell }}"          # shell to execute during `bertrand enter`
ignore = [              # ignore patterns shared between .gitignore and .containerignore
    ".bertrand/",
    "**/.bertrand/",
    "__pycache__/",
    "*.py[cod]",
    "*.egg-info/",
    ".dist/",
    ".build/",
    ".eggs/",
    ".venv/",
    "venv/",
    "build/",
    "out/",
    "*.o",
    "*.obj",
    "*.a",
    "*.lib",
    "*.so",
    "*.dylib",
    "*.dll",
    ".vscode/",
    ".idea/",
    ".DS_Store",
]
git_ignore = []         # additional .gitignore patterns
container_ignore = [    # additional .containerignore patterns
    ".git/",
    ".gitignore",
]
services = []           # optional service orchestration, using tags from the build matrix
                        # below.  If non-empty, then a `kube.yaml` artifact will be generated
                        # and played when starting the environment.  Each entry will be built
                        # and started in sequence, using its build matrix definition.

[tool.bertrand.network.build]
mode = "pasta"          # -> --network (none|host|ns:path|private|slirp4netns|pasta)
options = []            # mode-specific option tokens (see podman docs)
dns = []                # -> --dns (ip addresses of custom DNS servers)
dns_search = []         # -> --dns-search (custom DNS search domains)
dns_options = []        # -> --dns-option (DNS options, stored in `/etc/resolv.conf`)
add_host = {}           # -> --add-host (hostname = ip|"host-gateway", stored in `/etc/hosts`)

[tool.bertrand.network.run]
mode = "pasta"          # -> --network (none|host|ns:path|private|slirp4netns|pasta)
options = []            # mode-specific option tokens (see podman docs)
dns = []                # -> --dns (ip addresses of custom DNS servers)
dns_search = []         # -> --dns-search (custom DNS search domains)
dns_options = []        # -> --dns-option (DNS options, stored in `/etc/resolv.conf`)
add_host = {}           # -> --add-host (hostname = ip|"host-gateway", stored in `/etc/hosts`)

############################
####    BUILD MATRIX    ####
############################

# NOTE: `tag = ""` denotes the default container for an environment.  The
# default tag is intentionally exhaustive and self-documenting, with each
# option set to its default value.  Non-default tags should typically
# override only what they need.  See the `podman build` and `podman run`
# documentation for more details on what each options does.

[[tool.bertrand.tags]]
tag = ""
dependencies = []       # additional Python-level dependencies to install for this tag
containerfile = "Containerfile"  # -> --file, relative (posix) path from worktree root
build_args = {}         # -> --build-arg (key = value), passed into containerfile
env_file = []           # -> --env-file, relative (posix) path from worktree root
ports = [               # -> --publish
    # e.g. { container = 8000, host = 8000, host_ip = "127.0.0.1", protocol = "tcp" },
]
network_aliases = [     # -> --network-alias (for inter-tag network communication)
    # e.g. "postgres"
]
cpus = 0.0              # -> --cpus (can be >1 to use multiple cores, 0.0 => unlimited)
memory = "0"            # -> --memory ("0" => unlimited)
pids_limit = 2048       # -> --pids-limit  (max processes in container, -1 => unlimited)
shm_size = "64m"        # -> --shm-size  (size of `/dev/shm`, for IPC within a container)
ulimit = [              # -> --ulimit
    # e.g. { name = "nproc", soft = 4096, hard = 8192 },
]
cap_add = [             # -> --cap-add
    # e.g. "NET_BIND_SERVICE"
]
cap_drop = [            # -> --cap-drop
    # e.g. "ALL"
]
security_opt = [        # -> --security-opt
    # e.g. "no-new-privileges"
]
userns = ""             # -> --userns (""|host|private|keep-id|auto|nomap|ns:path)
ipc = "private"         # -> --ipc (none|shareable|<tag>|host|private|ns:path)
pid = "private"         # -> --pid (private|host|ns:path|container:<name|id>)
uts = "private"         # -> --uts (private|host|ns:path|container:<name|id>)
ssh = []                # SSH capability IDs (SCREAMING_SNAKE_CASE, e.g. ["GIT_SSH_KEY"]).
                        # Resolves to `podman build --ssh` entries.  No key material or
                        # socket paths are stored in project configuration.
instruments = []        # An array of tables representing runtime instrumentation tools
                        # (e.g. sanitizers, profilers, etc.) to apply to this tag.  See
                        # the `:debug` tag for example usage.

[tool.bertrand.tags.devices]
build = []              # Device capability IDs (SCREAMING_SNAKE_CASE, e.g. ["GPU"]).
                        # Resolves to `podman build --device` entries.
run = []                # Device capability IDs (SCREAMING_SNAKE_CASE, e.g. ["GPU"]).
                        # Resolves to `podman run --device` entries.  No device paths
                        # are stored in project configuration.

[tool.bertrand.tags.secrets]
build = []              # Secret IDs (SCREAMING_SNAKE_CASE, e.g. ["PYPI_TOKEN"]), passed
                        # as env vars during the build, but not persisted in the image.
run = []                # Secret IDs (SCREAMING_SNAKE_CASE, e.g. ["DB_PASSWORD"]), passed
                        # as podman secrets, which are exposed as files under `/run/secrets/`.
                        # No secret values are stored in project configuration.

[tool.bertrand.tags.conan]
requires = []           # e.g. ["boost/1.86.0"]
tool_requires = []      # e.g. ["protobuf/5.28.0"]
options = {}            # e.g. { "boost/*:without_test" = true }
conf = {}               # e.g. { "tools.cmake.cmaketoolchain:generator" = "Ninja" }
build_type = ""         # empty => inherit [tool.bertrand.conan].build_type

[tool.bertrand.tags.build]
context = "."           # build context path, relative to worktree root
target = ""             # -> --target (empty => final stage)
pull_policy = "missing" # -> --pull (missing|always|never|newer)

[tool.bertrand.tags.stop]
signal = "SIGTERM"      # -> --stop-signal
timeout = 10            # -> --stop-timeout

[tool.bertrand.tags.restart]
policy = "no"           # -> --restart (no|on-failure|always|unless-stopped)
max_retries = 0         # -> --restart-retries (only for on-failure, ignored otherwise)

[tool.bertrand.tags.healthcheck]
cmd = []                # -> --health-cmd (e.g. ["curl", "-f", "<ip>"], disabled when empty)
on_failure = "kill"     # -> --health-on-failure (none|kill|stop, "kill" invokes restart policy)
retries = 3             # -> --health-retries
interval = "30s"        # -> --health-interval
timeout = "30s"         # -> --health-timeout

[tool.bertrand.tags.healthcheck.startup]
cmd = []                # -> --health-startup-cmd (only during boot; failure implies "stop")
period = "0s"           # -> --health-start-period (overall time budget for healthcheck.startup)
success = 0             # -> --health-startup-success (successes needed to enter "healthy" state)
interval = "30s"        # -> --health-startup-interval
timeout = "30s"         # -> --health-startup-timeout

[tool.bertrand.tags.healthcheck.log]
destination = "local"   # -> --health-log-destination
max_count = 5           # -> --health-max-log-count
max_size = 500          # -> --health-max-log-size

# NOTE: `env:debug` compiles with debug assertions and instrumentation to detect
# memory errors and undefined behavior.  This tag is provided by default to simplify
# development and testing, as well as show how runtime instruments can be configured.
# The current list of supported instruments are:
#   -   asan (Address Sanitizer): detects memory errors such as buffer overflows,
#       use-after-free, and memory leaks.
#   -   msan (Memory Sanitizer): detects uninitialized memory reads, which can lead to
#       undefined behavior and security vulnerabilities.
#   -   tsan (Thread Sanitizer): detects data races and other threading issues in
#       concurrent code.
#   -   ubsan (Undefined Behavior Sanitizer): detects undefined behavior such as
#       integer overflows, null pointer dereferences, and misaligned pointer access.
#   -   valgrind: a suite of tools for memory debugging, memory leak detection, and
#       profiling.
#   -   lldb: an LLVM-native debugger that can be used for interactive debugging
#       sessions.
#   -   perf: a performance analysis tool for Linux that can be used to profile
#       CPU and memory usage, as well as other performance metrics.
#
# If multiple instruments are specified for a tag, Bertrand will attempt to execute
# them in the same order they are declared.  For each instrument, a `tool` key must
# be specified, which is used to locate a corresponding handler.  All other keys are
# passed as arguments to that handler, which produces the context necessary to apply
# the instrument at build and/or runtime.  See the `bertrand.env.instruments` module
# for more details.

[[tool.bertrand.tags]]
tag = "debug"
dependencies = []                   # additional Python-level dependencies for this tag
build_args = { DEBUG = true }

[tool.bertrand.tags.conan]
build_type = "Debug"                # compile conan dependencies in debug mode

[[tool.bertrand.tags.instruments]]
tool = "asan"
detect_leaks = "1"                  # report memory leaks at process exit
halt_on_error = "1"                 # abort on first ASan finding (fail-fast)
symbolize = "1"                     # resolve addresses to file:line/function in reports
detect_stack_use_after_return = "1" # detect stale stack references after function return
strict_string_checks = "1"          # tighten checks around libc string/memory functions
fast_unwind_on_fatal = "0"          # use slower precise unwinder for higher-fidelity traces

[[tool.bertrand.tags.instruments]]
tool = "ubsan"
undefined = "true"                  # enable broad undefined-behavior instrumentation
halt_on_error = "1"                 # abort on first UBSan finding (fail-fast)
print_stacktrace = "1"              # include stacktrace for each UB report
symbolize = "1"                     # resolve addresses to file:line/function in reports
report_error_type = "1"             # include UB category (e.g. signed-overflow)
print_summary = "1"                 # print end-of-run summary of UBSan reports

[[tool.bertrand.tags.instruments]]
tool = "lldb"
auto_run = true                     # launch target immediately inside LLDB
no_lldbinit = true                  # ignore host/user init files for reproducibility
source_quietly = true               # suppress echoed auto-issued LLDB commands
on_crash = [
    "thread backtrace all",
    "frame variable",
    "register read",
]

######################
####    PYTEST    ####
######################

[tool.pytest]
minversion = 9.0                    # minimum supported pytest version (>=9.0)
required_plugins = []               # pytest plugins that must be present for test execution
testpaths = ["tests"]               # default test discovery roots
python_files = ["test_*.py"]        # glob-style patterns for Python files to collect tests from
python_functions = ["test_*"]       # glob-style patterns for Python functions to collect as tests
python_classes = ["Test*"]          # glob-style patterns for Python classes to collect as tests
filterwarnings = []                 # ignore or error on specific warnings (see pytest docs)
markers = []                        # custom markers for test categorization (see pytest docs)
usefixtures = []                    # fixtures to auto-apply for all tests
addopts = ["-ra", "-q"]             # quiet output with short test summary
console_output_style = "progress"   # classic|progress|count|times
strict = true                       # prevent common testing footguns (see pytest docs)

##################
####    TY    ####
##################

# NOTE: These are balanced defaults for local development and CI, which are
# intentionally non-gating out of the box, and can be tightened as projects mature.

[tool.ty.src]
{% if project_layout == "src" %}
include = ["src", "tests"]          # relative paths ty should check
{% else %}
include = [".", "tests"]            # relative paths ty should check
{% endif %}
exclude = []                        # explicitly skipped paths
respect-ignore-files = true         # exclude paths in .gitignore

[tool.ty.rules]
# Overrides for specific rules go here.  See the ty documentation for the available
# rules.

####################
####    RUFF    ####
####################

[tool.ruff]
target-version = "py{{ python_major }}{{ python_minor }}"            # python syntax target
line-length = 100                   # max allowed line length
indent-width = 4                    # number of spaces per indentation level
output-format = "full"              # full|concise|grouped|json|junit|github|gitlab|pylint|azure
respect-gitignore = true            # exclude paths in .gitignore
unsafe-fixes = false                # do not display hints for potentially unsafe fixes

[tool.ruff.format]
exclude = []                        # glob-style paths to exclude from formatting
quote-style = "preserve"            # double|single|preserve (for string literals)
indent-style = "space"              # space|tab
skip-magic-trailing-comma = false   # trailing commas may enforce multi-line constructs
line-ending = "auto"                # auto|lf|cr-lf|native (auto infers from file)
docstring-code-format = true        # format inline code blocks in docstrings
docstring-code-line-length = "dynamic"  # int|"dynamic" ("dynamic" defers to line-length)

[tool.ruff.lint]
exclude = []                        # glob-style paths to exclude from linting
select = [                          # enabled rule families (see ruff docs for details)
    "E",
    "F",
    "I",
    "B",
    "UP"
]
ignore = []                         # suppressed rules
fixable = ["ALL"]                   # rules that auto-fix may modify source code
unfixable = []                      # rules to never auto-fix
extend-safe-fixes = []              # extra rules to treat as safe for auto-fixing
extend-unsafe-fixes = []            # extra rules to treat as unsafe for auto-fixing
per-file-ignores = {}               # e.g. { "path/to/file.py": ["E501", "F401"] }

# [tool.lint.flake8-*]
# [tool.lint.pylint-*]
# [tool.lint.isort-*]
# etc. for rule-specific formatting and linting options.  See the ruff documentation
# for supported rules and options.

######################
####    CLANGD    ####
######################

[tool.clangd.Diagnostics]
UnusedIncludes = "Strict"           # strict unused include diagnostics
MissingIncludes = "Strict"          # strict missing-include diagnostics
Suppress = []                       # diagnostics to suppress by code/category

[tool.clangd.Index]
Background = "Build"                # build/update background index

[tool.clangd.Completion]
AllScopes = true                    # include symbols from all visible scopes
HeaderInsertion = "IWYU"            # prefer include-what-you-use insertions

[tool.clangd.InlayHints]
Enabled = true                      # enable inlay hints globally
ParameterNames = true               # show argument/parameter name hints
DeducedTypes = true                 # show deduced type hints for auto/templated code
Designators = true                  # show designator hints for aggregate init

##########################
####    CLANG-TIDY    ####
##########################

[tool.clang-tidy]
FormatStyle = "file"                # always use generated .clang-tidy file
Checks = [                          # enabled check families (see clang-tidy docs for details)
    "clang-analyzer-*",
    "bugprone-*",
    "performance-*",
    "readability-*",
    "modernize-*",
    "cppcoreguidelines-*",
]
CheckOptions = {}                   # check-specific option overrides
WarningsAsErrors = []               # non-gating by default
HeaderFilterRegex = ".*"            # display diagnostics from all non-system headers
ExcludeHeaderFilterRegex = ""       # optional regex for headers to suppress
SystemHeaders = false               # suppress diagnostics from system headers
InheritParentConfig = true          # merge parent .clang-tidy configs when present
UseColor = true                     # color diagnostics when supported

############################
####    CLANG-FORMAT    ####
############################

# NOTE: These are opinionated defaults designed to make C++ code as familiar as
# possible to Python developers.  If your project has an existing style guide, or
# you prefer a more traditional C++ style, feel free to disable automatic formatting
# or modify these settings as needed.

[tool.clang-format]
DisableFormat = false               # enable/disable all formatting features
BasedOnStyle = "Mozilla"            # LLVM|Google|Chromium|Mozilla|WebKit|Microsoft|GNU
AccessModifierOffset = 0            # in indentation levels
AlwaysBreakBeforeMultilineStrings = true
AttributeMacros = [                 # names to recognize as custom language attributes
    "__declspec",
]
BinPackArguments = false            # all arguments appear on one line or separate lines each
BinPackLongBracedList = true        # override BinPackArguments for excessively long braced lists
BinPackParameters = "OnePerLine"    # BinPack|OnePerLine|AlwaysOnePerLine
BitFieldColonSpacing = "Both"       # Both|None|Before|After
ColumnLimit = 100
CompactNamespaces = false
Cpp11BracedListStyle = "FunctionCall"       # Block|FunctionCall|AlignFirstComment
EmptyLineAfterAccessModifier = "Never"      # Never|Leave|Always
EmptyLineBeforeAccessModifier = "Always"    # Never|Leave|LogicalBlock|Always
FixNamespaceComments = true                 # enforce closing comments for all namespaces
ForEachMacros = [                           # names of macros to recognize as foreach loops
    "Q_FOREACH",
    "BOOST_FOREACH",
]
IFMacros = [                        # names of macros to recognize as if statements
    "Q_IF",
]
IncludeBlocks = "Preserve"          # Preserve|Merge|Regroup
InsertBraces = true
InsertNewlineAtEOF = true
LineEnding = "DeriveLF"             # LF|CRLF|DeriveLF|DeriveCRLF
NamespaceIndentation = "None"       # None|Inner|All
NamespaceMacros = [                 # names to recognize as namespace definitions
    "__LIBCPP_BEGIN_NAMESPACE_STD",
]
OneLineFormatOffRegex = "NOFORMAT"  # regex to disable formatting for a single line
PackConstructorInitializers = "CurrentLine" # Never|BinPack|CurrentLine|NextLine|NextLineOnly
PointerAlignment = "Left"           # Left|Right|Middle
QualifierOrder = [
    "inline",
    "static",
    "constexpr",
    "friend",
    "const",
    "volatile",
    "type",
]
ReferenceAlignment = "Left"                     # Left|Right|Middle
ReflowComments = "Always"                       # Never|IndentOnly|Always
RemoveEmptyLinesInUnwrappedLines = true
RequiresClausePosition = "WithPreceding"        # OwnLine|OwnLineWithBrace|WithPreceding|WithFollowing|SingleLine
RequiresExpressionIndentation = "OuterScope"    # OuterScope|Keyword
SeparateDefinitionBlocks = "Always"             # Leave|Always|Never
SortUsingDeclarations = "Lexicographic"         # Never|Lexicographic|LexicographicNumeric
SpacesBeforeTrailingComments = 2
SpacesInAngles = "Never"                        # Never|Always|Leave
SpacesInContainerLiterals = false
SpacesInLineCommentPrefix = { Minimum = 1, Maximum = 1 }  # required space after `//`
SpacesInParens = "Custom"                       # Always set to "Custom" to use SpacesInParensOptions
SpacesInSquareBrackets = false
Standard = "Auto"                               # Always set to "Auto" to infer standard
TabWidth = 4
TemplateNames = [
    # e.g. "MYTEMPLATE" => `MYTEMPLATE<arg> void func() { ... }`
]
TypeNames = [
    # e.g. "MYTYPE" => `MYTYPE* var;` without a typename prefix
]
TypenameMacros = [
    # e.g. "MYTYPENAME" => `MYTYPENAME(typename) var;` without treating `MYTYPENAME` as a function
]
UseTab = "Never"                                # Never|ForIndentation|ForContinuationAndIndentation|AlignWithSpaces|Always
WrapNamespaceBodyWithEmptyLines = "Leave"       # Never|Always|Leave

[tool.clang-format.Align]
AfterOpenBracket = false            # horizontally align parameters after open paren/bracket
ArrayOfStructures = "None"          # Left|Right|None, for stacked initializer lists
EscapedNewlines = "Right"           # DontAlign|Left|LeftWithLastLine|Right
Operands = "Align"                  # DontAlign|Align|BreakBeforeBinaryOperators|AlignAfterOperator

[tool.clang-format.Align.ConsecutiveAssignments]
Enabled = false
AcrossEmptyLines = false
AcrossComments = false
AlignCompound = false               # treat compound assignments (e.g. +=) the same
PadOperators = false                # left-pad all assignments to longest compound operator

[tool.clang-format.Align.ConsecutiveBitFields]
Enabled = false
AcrossEmptyLines = false
AcrossComments = false

[tool.clang-format.Align.ConsecutiveDeclarations]
Enabled = false
AcrossEmptyLines = false
AcrossComments = false
AlignFunctionDeclarations = false   # vertically align function names
AlignFunctionPointers = true        # treat the `(*f)` part of `int(*f)()` as a declaration

[tool.clang-format.Align.ConsecutiveMacros]
Enabled = false
AcrossEmptyLines = false
AcrossComments = false

[tool.clang-format.Align.ConsecutiveShortCaseStatements]
Enabled = false
AcrossEmptyLines = false
AcrossComments = false
AlignCaseArrows = false
AlignCaseColons = false

[tool.clang-format.Align.TrailingComments]
Kind = "Never"                      # Leave|Always|Never
OverEmptyLines = false
AlignPPAndNotPP = true              # treat comments following preprocessor directives the same

[tool.clang-format.Allow]
AllArgumentsOnNextLine = false
AllParametersOfDeclarationOnNextLine = false
BreakBeforeNoexceptSpecifier = "OnlyWithParen"  # Never|OnlyWithParen|Always
ShortBlocksOnASingleLine = "Empty"              # Never|Empty|Always
ShortCaseExpressionsOnASingleLine = true
ShortCaseLabelsOnASingleLine = true
ShortCompoundRequirementsOnASingleLine = true
ShortEnumsOnASingleLine = true
ShortFunctionsOnASingleLine = "Always"          # None|Inline|InlineOnly|All
ShortIfStatementsOnASingleLine = "WithoutElse"  # None|WithoutElse|OnlyFirstIf|AllIfsAndElse
ShortLambdasOnASingleLine = "All"               # None|Empty|Inline|All
ShortLoopsOnASingleLine = true
ShortNamespacesOnASingleLine = false

[tool.clang-format.Break]
AdjacentStringLiterals = true
AfterAttributes = "Never"                       # Always|Leave|Never
AfterOpenBracketBracedList = true
AfterOpenBracketFunction = true
AfterOpenBracketIf = true
AfterOpenBracketLoop = true
AfterOpenBracketSwitch = true
AfterReturnType = "ExceptShortType"             # Automatic|ExceptShortType|All|TopLevel|AllDefinitions|TopLevelDefinitions
BeforeBinaryOperators = "None"                  # None|NonAssignment|All
BeforeBraces = "Custom"                         # Always set to "Custom" to use BraceWrapping
BeforeCloseBracketBracedList = true
BeforeCloseBracketFunction = true
BeforeCloseBracketIf = true
BeforeCloseBracketLoop = true
BeforeCloseBracketSwitch = true
BeforeConceptDeclarations = "Always"            # Always|Allowed|Never
BeforeInlineASMColon = "OnlyMultiline"          # Never|OnlyMultiline|Always
BeforeTemplateCloser = true
BeforeTernaryOperators = false
BinaryOperations = "Never"                      # Never|OnePerLine|RespectPrecedence
ConstructorInitializers = "AfterColon"          # BeforeColon|BeforeComma|AfterColon|AfterComma
FunctionDefinitionParameters = false
InheritanceList = "AfterColon"                  # BeforeColon|BeforeComma|AfterColon|AfterComma
StringLiterals = true
TemplateDeclarations = "Yes"                    # Leave|No|MultiLine|Yes

[tool.clang-format.BraceWrapping]
AfterCaseLabel = false
AfterClass = false
AfterControlStatement = "Never"     # Never|MultiLine|Always
AfterEnum = false
AfterFunction = false
AfterNamespace = false
AfterStruct = false
AfterUnion = false
AfterExternBlock = false
BeforeCatch = false
BeforeElse = false
BeforeLambdaBody = false
BeforeWhile = false
IndentBraces = false
SplitEmptyFunction = false
SplitEmptyRecord = false
SplitEmptyNamespace = false

[tool.clang-format.Indent]
CaseLabels = true
ExportBlock = true
ExternBlock = true
GotoLabels = true
PPDirectives = "BeforeHash"         # None|BeforeHash|AfterHash|Leave
RequiresClause = true
Width = 4
WrappedFunctionNames = false

[tool.clang-format.IntegerLiteralSeparator]
Binary = 8                          # -1 => unlimited (requires 0b prefix)
Decimal = -1                        # -1 => unlimited
Hex = 4                             # -1 => unlimited (requires 0x prefix)

[tool.clang-format.KeepEmptyLines]
AtEndOfFile = false
AtStartOfBlock = false
AtStartOfFile = false

[tool.clang-format.NumericLiteralCase]
ExponentLetter = "Lower"            # Leave|Lower|Upper
HexDigit = "Upper"                  # Leave|Lower|Upper
Prefix = "Lower"                    # Leave|Lower|Upper
Suffix = "Lower"                    # Leave|Lower|Upper

[tool.clang-format.SortIncludes]
Enabled = true
IgnoreCase = false
IgnoreExtension = false

[tool.clang-format.Space]
AfterCStyleCast = false
AfterLogicalNot = false
AfterOperatorKeyword = false
AfterTemplateKeyword = false
BeforeAssignmentOperators = true
BeforeCaseColon = false
BeforeCpp11BracedList = false
BeforeCtorInitializerColon = true
BeforeInheritanceColon = true
BeforeJSonColon = false
BeforeParens = "Custom"             # Always set to "Custom" to use BeforeParensOptions
BeforeRangeBasedForLoopColon = true
BeforeSquareBrackets = false
InEmptyBraces = "Never"             # Always|Block|Never

[tool.clang-format.Space.BeforeParensOptions]
AfterControlStatements = true
AfterForeachMacros = true
AfterFunctionDeclarationName = false
AfterFunctionDefinitionName = false
AfterIfMacros = true
AfterNot = true
AfterOverloadedOperator = false
AfterPlacementOperator = true
AfterRequiresInClause = false
AfterRequiresInExpression = false
BeforeNonEmptyParentheses = false

[tool.clang-format.SpacesInParensOptions]
ExceptDoubleParentheses = false
InConditionalStatements = false
InCStyleCasts = false
InEmptyParentheses = false
Other = false
